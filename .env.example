# ==========================================
# PENTA Content Planner — variáveis de ambiente
# Copie este arquivo pra .env e preencha
# ==========================================

# ----- Auth -----
# Senha única de acesso ao app (qualquer pessoa que souber entra).
# Se deixar VAZIA, o app fica sem auth (modo dev local).
APP_PASSWORD=defina-uma-senha-forte-aqui

# Segredo pra assinar cookies de sessão (use 32+ chars aleatórios)
# Pode gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=substitua-por-string-aleatoria-longa

# ----- Claude API -----
# Chave da Anthropic API (pegue em console.anthropic.com)
# Se vazia, o botão "Gerar com IA" mostra erro amigável
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----- Storage -----
# Backend de storage: "fs" (local, default) ou "s3" (Cloudflare R2 / AWS S3)
# Em produção no Render free tier, use "s3" porque não há disco persistente.
STORAGE_BACKEND=fs

# ----- Cloudflare R2 (só preencha se STORAGE_BACKEND=s3) -----
# 1. Crie conta gratuita em cloudflare.com
# 2. Vá em R2 → Create bucket → nome do bucket
# 3. Vá em Manage R2 API tokens → Create token (Object Read & Write no bucket)
# 4. Copie Account ID, Access Key ID, Secret Access Key
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=cole-aqui
R2_SECRET_ACCESS_KEY=cole-aqui
R2_BUCKET=penta-planner

# ----- Servidor -----
# Porta (padrão 5000; o Render seta PORT automaticamente)
PORT=5000
